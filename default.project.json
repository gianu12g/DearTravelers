{
  "name": "Dear Travelers",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": "Packages"
      },

      "ReplicaShared": {
        "$path": "src/vendor/Replica/ReplicaShared"
      },
      "ReplicaClient": {
        "$path": "src/vendor/Replica/ReplicaClient.luau"
      },

      "rbxts_include": {
        "$path": "include",
        "node_modules": {
          "$className": "Folder",
          "@rbxts": {
            "$path": "node_modules/@rbxts"
          },
          "@rbxts-js": {
            "$path": "node_modules/@rbxts-js"
          }
        }
      },
      "TS": {
        "$path": { "optional": "out/shared" }
      }
    },

    "ServerScriptService": {
      "Main": {
        "$path": "src/server/Main.server.luau"
      }
    },

    "ServerStorage": {
      "Services": {
        "$path": "src/server/Services"
      },
      "Modules": {
        "$path": "src/server/Modules"
      },
      "ServerPackages": {
        "$path": "ServerPackages"
      },

      "ReplicaServer": {
        "$path": "src/vendor/Replica/ReplicaServer.luau"
      },

      "TS": {
        "$path": { "optional": "out/server" }
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Main": {
          "$path": "src/client/Main.client.luau"
        },
        "Controllers": {
          "$path": "src/client/Controllers"
        },
        "UI": {
          "$path": "src/client/UI"
        },

        "TS": {
          "$path": { "optional": "out/client" }
        }
      }
    }
  }
}